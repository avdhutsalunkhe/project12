# ──────────────────────────────────────────────
# SHL Assessment Recommendation System — Config
# ──────────────────────────────────────────────

# Application
APP_NAME="SHL Assessment Recommender"
APP_VERSION="0.1.0"
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# CORS (JSON array of origins)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# API Keys (add as needed)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
